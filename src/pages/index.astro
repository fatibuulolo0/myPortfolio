---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import { sortItemsByDateDesc, withBase } from "../utils/helpers";
import PostCardPreview from "../components/PostCardPreview.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/images/profile_picture.png";
import ArrowRight from "../icons/ArrowRight.astro";

const allPosts = (await getCollection("blogs")).sort(sortItemsByDateDesc);
const techIcons = [
  { name: "Python", src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg", class: "top-0 left-1/4 w-16 h-16 blur-[1px]", delay: "0s" },
  { name: "SQL", src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg", class: "bottom-10 left-0 w-14 h-14 blur-[2px]", delay: "1.5s" },
  { name: "TensorFlow", src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tensorflow/tensorflow-original.svg", class: "top-1/4 right-0 w-20 h-20", delay: "0.5s" },
  { name: "Math", src: "https://img.icons8.com/ios-filled/100/222222/pi.png", class: "bottom-0 right-1/4 w-12 h-12 blur-[3px] opacity-40", delay: "2s" },
];

---

<MainLayout activePage="home" pageTitle={siteConfig.title + " | Fati Buulolo"}>
  <div class="jumbo-banner flex flex-col md:flex-row items-center justify-between w-full px-4 my-12 gap-12">
    
    <div class="w-full md:w-1/2">
      {siteConfig.hero?.eyebrowText && (
        <span class="tag rounded-full text-xs px-2 py-0 border border-gray-500 kanit-light">
          {siteConfig.hero?.eyebrowText}
        </span>
      )}
      <h1 class="sigmar-ff leading-tight text-balance sm:pt-0! text-5xl md:text-7xl">
        {siteConfig.hero?.title}
      </h1>
      <p class="kanit-regular text-balance text-sm md:text-lg opacity-80">
        {siteConfig.hero?.text}
      </p>
      <div class="flex flex-wrap items-center gap-4 mt-8">
        {siteConfig.hero?.actions?.map((action, index) => (
          <Button href={action.href} class={index === 0 ? "space-btn-filled" : "space-btn-outlined"}>
            {action.text}
          </Button>
        ))}
      </div>
    </div>

    <div class="relative w-full md:w-1/2 h-[300px] flex items-center justify-center pointer-events-none">
      <div class="relative w-full h-full max-w-[400px]">
        {techIcons.map((icon) => (
          <div 
            class:list={["absolute animate-float transition-all duration-700", icon.class]}
            style={`animation-delay: ${icon.delay};`}
          >
            <img src={icon.src} alt={icon.name} class="w-full h-full object-contain filter drop-shadow-xl" />
          </div>
        ))}
      </div>
    </div>

  </div>

  <div class="page-content">...</div>
</MainLayout>
<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(5deg);
    }
  }

  .animate-float {
    animation: float 6s infinite ease-in-out;
  }

  /* Menambahkan efek glow tipis di belakang area ikon */
  .jumbo-banner::after {
    content: '';
    position: absolute;
    right: 10%;
    top: 20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(0,0,0,0.05) 0%, transparent 70%);
    z-index: -1;
  }
</style>
