---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import coverImage from "../assets/images/profile_picture.png";
---

<MainLayout activePage="about" pageTitle={siteConfig.title + " | About"}>
  <div class="page-content">
    <h1 class="sigmar-ff text-balance">{siteConfig.about?.title}</h1>
    <Image
      width={300}
      height={400}
      loading="eager"
      layout="constrained"
      class="rounded-4xl mb-8 mx-auto"
      src={coverImage}
      alt="An Astronaut walking on a terrain"
    />
    <p class="kanit-light text-left">
      {siteConfig.about?.text}
    </p>
    <h2 class="sigmar-ff text-balance mt-12 mb-6 text-2xl">Intellectual Property (HAKI)</h2>
    <div class="space-y-8 text-left">
      <div class="kanit-light border-l-4 border-zinc-500 pl-4">
        <p class="font-bold text-lg mb-2">Software Application: Stock Price Forecaster</p>
        <p class="mb-2">
          Copyright registration issued by DJKI, providing legal protection for an original software application designed to generate one-month stock price forecasts in full candlestick format. The application implements a multi-step prediction workflow, offering a more advanced output compared to conventional next-day or line-chart forecasting tools.
        </p>
        <p class="text-sm font-mono opacity-70">Credential ID: EC002025132107</p>
        <strong style="background-color:#c9b99a; padding: 2px 6px; border-radius: 4px;">
          <a href="https://drive.google.com/file/d/1ZjXHqbvVykHr6B-GXkT8CUCTxZBibXps/view?usp=sharing">View Document</a>
        </strong>
      </div>

      <div class="kanit-light border-l-4 border-zinc-500 pl-4">
        <p class="font-bold text-lg mb-2">Research Work: Candlestick-Based Forecasting</p>
        <p class="mb-2">
          Copyright registration issued by DJKI, granting legal protection for the original research work on one-month stock price forecasting using candlestick-based prediction outputs. This work introduces a forecasting approach that extends beyond typical next-day or line-chart predictions, producing multi-step outputs in full candlestick format.
        </p>
        <p class="text-sm font-mono opacity-70">Credential ID: EC002025124228</p>
        <strong style="background-color:#c9b99a; padding: 2px 6px; border-radius: 4px;">
          <a href="https://drive.google.com/file/d/1lJxiWz60ENshkuUB0QCV50uhDzB2F0ML/view?usp=sharing">View Document</a>
        </strong>
      </div>
    </div>
  </div>
</MainLayout>
