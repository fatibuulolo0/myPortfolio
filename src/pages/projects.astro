---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import { sortItemsByDateDesc, withBase } from "../utils/helpers";

// Mengambil semua post dari content/blogs - otomatis tersinkron dengan Home!
const allProjects = (await getCollection("blogs")).sort(sortItemsByDateDesc);
---

<MainLayout activePage="projects" pageTitle="Projects | Portofolio">
  <div class="page-content">
    <h1 class="sigmar-ff text-center pt-8 pb-4">Projects</h1>
    <p class="text-center kanit-light mb-12">Things I've built & worked on</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 px-4 pb-16">
      {allProjects.map((project) => (
        
          href={withBase(`/blog/${project.slug}`)}
          class="group block rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-all duration-200"
        >
          {project.data.image && (
            <div class="overflow-hidden h-48">
              <img
                src={project.data.image.src}
                alt={project.data.image.alt || project.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          )}
          <div class="p-5">
            <h2 class="sigmar-ff text-lg mb-2 group-hover:text-red-500 transition-colors">
              {project.data.title}
            </h2>
            <p class="kanit-light text-xs text-gray-500 mb-2">
              {new Date(project.data.publishDate).toLocaleDateString("id-ID", {
                year: "numeric", month: "long", day: "numeric"
              })}
            </p>
            <p class="kanit-regular text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
              {project.data.excerpt}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</MainLayout>
