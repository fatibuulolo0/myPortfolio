---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import { sortItemsByDateDesc, withBase } from "../utils/helpers";

const allProjects = (await getCollection("blogs")).sort(sortItemsByDateDesc);

const projects = allProjects.map(project => {
  const d = project.data.pubDate;
  const dateObj = new Date(d);
  const day = dateObj.getDate();
  const month = dateObj.getMonth() + 1;
  const year = dateObj.getFullYear();
  const formattedDate = day + "/" + month + "/" + year;
  const href = withBase("/blog/" + project.id);
  const title = project.data.title;
  const excerpt = project.data.description;
  const tags = project.data.tags;
  const hasImage = project.data.image ? true : false;
  const imageSrc = project.data.image ? project.data.image.url.src : "";
  const imageAlt = project.data.image ? project.data.image.alt : "";
  return { href, formattedDate, title, excerpt, tags, hasImage, imageSrc, imageAlt };
});
---

<MainLayout activePage="projects" pageTitle={siteConfig.title + " | Projects"}>
  <div class="page-content">
    <h1 class="sigmar-ff text-center pt-8 pb-2">Projects</h1>
    <p class="kanit-light text-center mb-12 text-sm">Things I have built and worked on</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 px-4 pb-16">
      {projects.map(project => (
        <a
          href={project.href}
          class="group block rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-all duration-200 no-underline"
        >
          {project.hasImage && (
            <div class="overflow-hidden h-48">
              <img
                src={project.imageSrc}
                alt={project.imageAlt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          )}
          <div class="p-5">
            <h2 class="sigmar-ff text-lg mb-2 group-hover:text-red-500 transition-colors">
              {project.title}
            </h2>
            <p class="kanit-light text-xs text-gray-500 mb-3">
              {project.formattedDate}
            </p>
            <p class="kanit-regular text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
              {project.excerpt}
            </p>
            {project.tags && (
              <div class="flex flex-wrap gap-2 mt-3">
                {project.tags.map(tag => (
                  <span class="tag rounded-full text-xs px-2 py-0 border border-gray-400 kanit-light">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</MainLayout>
